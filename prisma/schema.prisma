generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  passwordHash      String
  name              String
  isAgent           Boolean           @default(false)
  createdAt         DateTime          @default(now())
  orgMembers        OrgMember[]
  teamMembers       TeamMember[]
  assignedCards     Card[]            @relation("CardAssignee")
  createdCards      Card[]            @relation("CardCreator")
  reviewedCards     Card[]            @relation("CardReviewer")
  approvedCards     Card[]            @relation("CardApprover")
  comments          Comment[]
  uploadedArtifacts Artifact[]
  signoffs          Signoff[]
  reportedTickets   Ticket[]          @relation("TicketReporter")
  assignedTickets   Ticket[]          @relation("TicketAssignee")
  ticketComments    TicketComment[]
  ticketActivity    TicketActivity[]
  googleCredential  GoogleCredential?

  @@map("users")
}

model Organization {
  id         String          @id @default(cuid())
  name       String
  slug       String          @unique
  createdAt  DateTime        @default(now())
  members    OrgMember[]
  teams      Team[]
  boards     Board[]
  apiKeys    ApiKey[]
  activities AgentActivity[]
  movements  CardMovement[]
  webhooks   Webhook[]
  tickets    Ticket[]
  aiSettings OrgAiSettings?

  @@map("organizations")
}

model OrgAiSettings {
  id                       String       @id @default(cuid())
  orgId                    String       @unique
  org                      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  anthropicApiKeyEncrypted String?
  anthropicApiKeyLastFour  String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@map("org_ai_settings")
}

model OrgMember {
  userId String
  orgId  String
  role   String       @default("MEMBER")
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@map("org_members")
}

model Team {
  id      String       @id @default(cuid())
  name    String
  orgId   String
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@map("team_members")
}

model Board {
  id        String       @id @default(cuid())
  name      String
  orgId     String
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  columns   Column[]
  sprints   Sprint[]
  cards     Card[]
  labels    Label[]
  movements CardMovement[]

  @@map("boards")
}

model Column {
  id       String @id @default(cuid())
  name     String
  boardId  String
  position Int
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards    Card[]

  @@map("columns")
}

model Sprint {
  id        String   @id @default(cuid())
  name      String
  boardId   String
  startDate DateTime
  endDate   DateTime
  status    String   @default("PLANNING")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@map("sprints")
}

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?
  columnId    String
  boardId     String
  sprintId    String?
  // Required at the API layer (Zod). DB-nullable for SQLite ALTER COLUMN practicality.
  assigneeId  String?
  agentId     String?
  priority    String    @default("none")
  position    Int
  dueDate     DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reviewerId     String?
  approverId     String?
  parentCardId   String?
  path           String  @default("") // "/ancestorA/ancestorB/" — empty for root cards
  depth          Int     @default(0)
  aiAutoReview   Boolean @default(false)
  aiReviewParams String? // JSON string: { model, rubric, customInstructions? }

  column     Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  board      Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  sprint     Sprint?         @relation(fields: [sprintId], references: [id])
  assignee   User?           @relation("CardAssignee", fields: [assigneeId], references: [id])
  createdBy  User            @relation("CardCreator", fields: [createdById], references: [id])
  reviewer   User?           @relation("CardReviewer", fields: [reviewerId], references: [id])
  approver   User?           @relation("CardApprover", fields: [approverId], references: [id])
  parent     Card?           @relation("CardChildren", fields: [parentCardId], references: [id], onDelete: SetNull)
  children   Card[]          @relation("CardChildren")
  labels     CardLabel[]
  comments   Comment[]
  artifacts  Artifact[]
  signoffs   Signoff[]
  aiReviews  AiReview[]
  executions CardExecution[]
  movements  CardMovement[]

  @@index([parentCardId])
  @@index([path])
  @@map("cards")
}

model CardMovement {
  id           String   @id @default(cuid())
  cardId       String
  boardId      String
  orgId        String
  fromColumnId String?
  toColumnId   String
  movedById    String
  movedByKind  String   // "user" | "agent"
  movedAt      DateTime @default(now())

  card  Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  board Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([cardId, movedAt])
  @@index([boardId, movedAt])
  @@index([orgId, movedAt])
  @@map("card_movements")
}

model Label {
  id      String      @id @default(cuid())
  name    String
  color   String
  boardId String
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   CardLabel[]

  @@map("labels")
}

model CardLabel {
  cardId  String
  labelId String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@map("card_labels")
}

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String?
  agentId   String?
  content   String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@map("comments")
}

model ApiKey {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  keyHash     String       @unique
  agentName   String
  permissions String
  lastUsedAt  DateTime?
  createdAt   DateTime     @default(now())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model AgentActivity {
  id           String       @id @default(cuid())
  orgId        String
  agentName    String
  action       String
  resourceType String
  resourceId   String
  metadata     String
  createdAt    DateTime     @default(now())
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("agent_activities")
}

model Webhook {
  id        String       @id @default(cuid())
  orgId     String
  url       String
  events    String
  secret    String
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ─── Review Workflow ─────────────────────────────────────────────────────────

model Artifact {
  id         String   @id @default(cuid())
  cardId     String
  uploaderId String
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  // values: UPLOAD (M1); reserved for M2: GOOGLE_DOC | GOOGLE_SHEET | GOOGLE_SLIDE | URL
  source     String   @default("UPLOAD")
  createdAt  DateTime @default(now())

  parentArtifactId String?
  parent           Artifact?  @relation("ArtifactChildren", fields: [parentArtifactId], references: [id], onDelete: SetNull)
  children         Artifact[] @relation("ArtifactChildren")

  card     Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploader User       @relation(fields: [uploaderId], references: [id])
  reviews  AiReview[]

  @@index([cardId])
  @@index([parentArtifactId])
  @@map("artifacts")
}

model AiReview {
  id             String    @id @default(cuid())
  artifactId     String?
  cardId         String
  // values: pending | running | done | failed | skipped
  status         String    @default("pending")
  model          String
  rubricSnapshot String
  instructions   String?
  output         String?
  errorMessage   String?
  inputTokens    Int?
  outputTokens   Int?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  artifact Artifact? @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  card     Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([artifactId])
  @@index([cardId])
  @@index([status])
  @@map("ai_reviews")
}

model Signoff {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  // values: REVIEWER | APPROVER
  role      String
  // values: APPROVED | REJECTED | REQUESTED_CHANGES
  decision  String
  comment   String?
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([cardId])
  @@map("signoffs")
}

// ─── Helpdesk / Ticketing ────────────────────────────────────────────────────

model Ticket {
  id          String    @id @default(cuid())
  orgId       String
  number      Int
  title       String
  description String?
  status      String    @default("open")
  priority    String    @default("medium")
  reporterId  String?
  assigneeId  String?
  agentName   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?

  org      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reporter User?            @relation("TicketReporter", fields: [reporterId], references: [id])
  assignee User?            @relation("TicketAssignee", fields: [assigneeId], references: [id])
  comments TicketComment[]
  activity TicketActivity[]

  @@unique([orgId, number])
  @@map("tickets")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String?
  agentName String?
  content   String
  internal  Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@map("ticket_comments")
}

model TicketActivity {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String?
  agentName String?
  action    String
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@map("ticket_activity")
}

// ─── Card Execution (M2) ──────────────────────────────────────────────────────

// CardExecutionState values: enqueued | running | done | failed | cancelled | interrupted
// SQLite has no native enum type; Prisma client enforces valid values at runtime.

model CardExecution {
  id     String @id @default(cuid())
  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  jobId String?
  // values: enqueued | running | done | failed | cancelled | interrupted
  state String

  project String
  branch  String
  spec    String

  output       String?
  errorMessage String?

  enqueuedAt DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([cardId])
  @@index([state])
  @@map("card_executions")
}

// ─── Host Meeting HUD (live in-meeting copilot) ──────────────────────────────
// See docs/specs/host-meeting-hud-addendum.md. All cross-module refs are kept as
// plain nullable Strings (no Prisma relation) per the spec's "nullable FK, DB
// permissive" convention, so the HUD ships independently of the Meeting models.

model HudSession {
  id        String   @id @default(cuid())
  orgId     String
  chairId   String // the present human (User id)
  // Soft links — all nullable so the HUD is standalone-capable:
  boardId   String? // board in focus (pertinent-panel source)
  seriesId  String? // MeetingSeries id, once that model exists
  meetingId String? // Meeting id, once that model exists
  title     String
  // values: live | ended
  status    String   @default("live")
  startedAt DateTime @default(now())
  endedAt   DateTime?

  dispatches AgentDispatch[]
  entries    HudEntry[]

  @@index([orgId, status])
  @@map("hud_sessions")
}

model AgentDispatch {
  id           String  @id @default(cuid())
  orgId        String
  hudSessionId String
  chairId      String // requester (audit)
  // values: board | drive | email | slack
  target       String
  question     String
  // values: queued | running | done | failed | cancelled
  status       String  @default("queued")
  answer       String? // rendered markdown
  // JSON: [{ kind, id, title, url?, quote? }] — evidence the answer rests on
  citations    String?
  confidence   Float?
  // When the agent suggests a board change, the pending ChangeSet id lands here.
  // The change is NEVER applied live — it surfaces for post-meeting human approval.
  proposedChangeSetId String?
  jobId        String? // external ClaudeMCP job id, if used
  error        String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?

  hudSession HudSession @relation(fields: [hudSessionId], references: [id], onDelete: Cascade)

  @@index([hudSessionId, status])
  @@index([status])
  @@map("agent_dispatches")
}

model HudEntry {
  id           String    @id @default(cuid())
  orgId        String
  hudSessionId String
  authorId     String // human User id — entries are never agent-authored
  // values: agenda | note | decision | action
  kind         String
  text         String
  position     Int       @default(0) // ordering within (session, kind)
  checkedAt    DateTime? // agenda: when checked off
  assigneeId   String? // action: resolved org member
  dueDate      DateTime? // action: parsed due date
  cardId       String? @unique // action: card created from this entry — unique guard for convert idempotence (SQLite allows multiple NULLs)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  hudSession HudSession @relation(fields: [hudSessionId], references: [id], onDelete: Cascade)

  @@index([hudSessionId, kind, position])
  @@map("hud_entries")
}

// ─── ChangeSet (chair-approved board mutations) ──────────────────────────────
// Minimal realization of MEETINGCOPILOTSPEC §3.2. meetingId is nullable so the
// HUD's "agent proposes, human approves" path works before the Meeting pipeline
// exists. Decision/apply endpoints require a human iron-session — never API-key.

model ChangeSet {
  id          String  @id @default(cuid())
  orgId       String
  boardId     String? // resolution/apply scope
  meetingId   String? // origin meeting, once that model exists
  hudSessionId String? // origin HUD session, when proposed live
  dispatchId   String? // origin AgentDispatch, when proposed by a dispatched agent
  // values: pending | partially_applied | applied | rejected | expired
  status       String  @default("pending")
  createdById  String // service user / agent name that proposed it
  approvedById String?
  summary      String?
  createdAt    DateTime  @default(now())
  appliedAt    DateTime?

  items ChangeItem[]

  @@index([orgId, status])
  @@index([hudSessionId])
  @@map("change_sets")
}

model ChangeItem {
  id          String @id @default(cuid())
  changeSetId String
  // values: create_card | move_card | update_card | comment_card |
  //         create_commitment | update_commitment_status | link_commitment_to_card
  op          String
  // JSON op payload, validated per-op by Zod at propose + apply time
  payload     String
  targetCardId       String?
  targetCommitmentId String?
  // JSON: { matchedId, matchedTitle, score, alternates: [{id,title,score}] }
  resolution  String?
  // JSON evidence span: { artifactId?, startMs?, endMs?, speakerLabel?, quote }
  evidence    String?
  confidence  Float?
  // values: pending | approved | rejected | retargeted
  decision    String  @default("pending")
  decidedById String?
  appliedAt   DateTime?
  error       String?

  changeSet ChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@index([changeSetId])
  @@map("change_items")
}

// ─── Google OAuth Credentials (M4) ───────────────────────────────────────────

model GoogleCredential {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshTokenEncrypted String // ciphertext only — never log
  accessTokenExpiresAt  DateTime?

  googleEmail String
  googleSub   String @unique
  scopes      String // space-separated

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  @@map("google_credentials")
}
