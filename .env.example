# Required
SESSION_SECRET=
DATABASE_URL=file:./kanban.db
COOKIE_SECURE=false   # set true behind HTTPS
# AI review transport.
#
# Primary: ClaudeMCP (https://github.com/cunninghambe/ClaudeMCP). Submits text
# reviews to a local ClaudeMCP HTTP MCP server and polls until done. Uses your
# Claude Code subscription (no API spend). Token counts not surfaced — reported
# as 0. Image artifacts cannot traverse this path; they fall through to the
# Anthropic API below.
CLAUDEMCP_URL=
CLAUDEMCP_PROJECT=
CLAUDEMCP_TIMEOUT_MS=600000

# Failover (or primary, if CLAUDEMCP_URL/PROJECT unset): Anthropic API.
# Either ANTHROPIC_API_KEY OR CLAUDE_CODE_OAUTH_TOKEN.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# AI review defaults (applied when card has no aiReviewParams and no ancestor has any)
AI_REVIEW_DEFAULT_MODEL=claude-sonnet-4-6
AI_REVIEW_DEFAULT_RUBRIC=

# Optional: avoid in-memory cache lookup of the AI Reviewer service user.
# Run `npm run db:seed-ai-reviewer` and copy the printed cuid here.
AI_REVIEWER_USER_ID=

# Storage
STORAGE_DRIVER=local        # 'local' | 's3' (s3 stub in M1)
UPLOAD_DIR=./uploads/

# Settings encryption — required for storing org-level secrets (e.g. Anthropic API key).
# Generate: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=

# Email digest
EMAIL_PROVIDER=log          # 'log' (default) | 'resend' (M2/M3)
CRON_SECRET=                # shared bearer token for POST /api/cron/digest

# mhud — the Host Meeting HUD (live in-meeting copilot)
# Design: docs/specs/host-meeting-hud-addendum.md · Agent setup: docs/mhud-dispatch-agent-setup.md
# NOTE: DATABASE_URL file: paths resolve relative to the prisma/ schema dir,
# so file:./kanban.db above becomes prisma/kanban.db (not repo-root).
CHANGESET_TTL_DAYS=14        # proposed ChangeSets expire after this many days (POST /api/cron/expire-changesets)
# Dispatched agents run on the external ClaudeMCP server (reuses CLAUDEMCP_URL).
# The ClaudeMCP project must be configured READ-ONLY and hold the actual access
# to the dispatch targets (boards via the read-scoped /api/mcp key below; Drive,
# Gmail, and Slack via that project's own MCP tool config — KanbanMCP itself has
# no Slack/Gmail substrate). Suggested board changes come back as proposals only.
HUD_DISPATCH_PROJECT=        # ClaudeMCP project for HUD dispatch (falls back to CLAUDEMCP_PROJECT)
HUD_DISPATCH_MAX_MS=300000   # per-dispatch timeout
HUD_DISABLE_DISPATCH_BOOTSTRAP=  # set to 1 to skip re-enqueuing in-flight dispatches on boot (ops/demo)
# Capability gate: comma-separated targets the external agent can actually answer.
# Unset (or all-invalid) = all four. Set e.g. "board,drive" if the ClaudeMCP project
# has no Gmail/Slack tools, so those chips are disabled instead of failing mid-meeting.
HUD_ENABLED_TARGETS=         # e.g. board,drive,email,slack
# Cost guards — each dispatch is a real, paid ClaudeMCP job:
HUD_MAX_INFLIGHT_PER_SESSION=3   # max queued+running dispatches per HUD session
HUD_MAX_INFLIGHT_PER_ORG=8       # max queued+running dispatches per org
HUD_BOARD_CONTEXT_MAX_CHARS=16000  # hard cap on the serialized board snapshot in the prompt
# Cancelling a dispatch (or ending a session) propagates to ClaudeMCP via
# claude_job_cancel on the worker's next poll (≤2s). Note: a dispatch cancelled
# while no worker is polling it (e.g. a crash between submit and re-enqueue) may
# still run to completion on ClaudeMCP — the local state is authoritative.
# Create a read-scoped ApiKey for the dispatch agent to call back into KanbanMCP:
# its permissions must be ["read","propose"] — this blocks every mutation tool
# (create_card/move_card/...) while allowing reads + propose_changeset.

# uh-oh crash reporting (self-hosted, github.com/cunninghambe/uh-oh).
# Format: https://<publicKey>@<uh-oh-host>[:port][/pathPrefix]. Leave unset to
# disable (the vendored client no-ops silently with no DSN).
UH_OH_DSN=
# Browser-side DSN, exposed to the client bundle (instrumentation-client.ts).
# Usually the same value as UH_OH_DSN unless you route browser/server events
# through different uh-oh projects.
NEXT_PUBLIC_UH_OH_DSN=

# uh-oh source map upload - DEPLOY-TIME ONLY. Read at `npm run build` (gates
# whether Next even generates .map files - see next.config.js) and by
# scripts/uh-oh-postbuild.mjs (uploads them, then deletes the browser copies).
# The running app never reads these; do not add them to the app's runtime
# environment, only to the shell/CI environment that runs the build.
UH_OH_SERVER_URL=
UH_OH_SYMBOL_TOKEN=
UH_OH_PROJECT=

# mhud inbox agent (Gmail triage → board; see docs/specs/mhud-inbox-agent.md
# and integrations/gmail-apps-script/SETUP.md)
INBOX_AGENT_URL=       # Apps Script web-app /exec URL (draft|send|ack proxy target)
INBOX_AGENT_TOKEN=     # shared secret; server-side only, never shipped to the browser
INBOX_BOARD_ID=        # board that receives triage cards (enables /api/cron/inbox-expire)
INBOX_EXPIRE_DAYS=5    # untouched triage cards roll into the Digest column after this