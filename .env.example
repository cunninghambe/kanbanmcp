# Required
SESSION_SECRET=
DATABASE_URL=file:./kanban.db
COOKIE_SECURE=false   # set true behind HTTPS
# AI review transport.
#
# Primary: ClaudeMCP (https://github.com/cunninghambe/ClaudeMCP). Submits text
# reviews to a local ClaudeMCP HTTP MCP server and polls until done. Uses your
# Claude Code subscription (no API spend). Token counts not surfaced — reported
# as 0. Image artifacts cannot traverse this path; they fall through to the
# Anthropic API below.
CLAUDEMCP_URL=
CLAUDEMCP_PROJECT=
CLAUDEMCP_TIMEOUT_MS=600000

# Failover (or primary, if CLAUDEMCP_URL/PROJECT unset): Anthropic API.
# Either ANTHROPIC_API_KEY OR CLAUDE_CODE_OAUTH_TOKEN.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# AI review defaults (applied when card has no aiReviewParams and no ancestor has any)
AI_REVIEW_DEFAULT_MODEL=claude-sonnet-4-6
AI_REVIEW_DEFAULT_RUBRIC=

# Optional: avoid in-memory cache lookup of the AI Reviewer service user.
# Run `npm run db:seed-ai-reviewer` and copy the printed cuid here.
AI_REVIEWER_USER_ID=

# Storage
STORAGE_DRIVER=local        # 'local' | 's3' (s3 stub in M1)
UPLOAD_DIR=./uploads/

# Settings encryption — required for storing org-level secrets (e.g. Anthropic API key).
# Generate: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=

# Email digest
EMAIL_PROVIDER=log          # 'log' (default) | 'resend' (M2/M3)
CRON_SECRET=                # shared bearer token for POST /api/cron/digest

# Host Meeting HUD (live in-meeting copilot) — see docs/specs/host-meeting-hud-addendum.md
# Dispatched agents run on the external ClaudeMCP server (reuses CLAUDEMCP_URL).
# The ClaudeMCP project must be configured READ-ONLY and hold the actual access
# to the dispatch targets (boards via the read-scoped /api/mcp key below; Drive,
# Gmail, and Slack via that project's own MCP tool config — KanbanMCP itself has
# no Slack/Gmail substrate). Suggested board changes come back as proposals only.
HUD_DISPATCH_PROJECT=        # ClaudeMCP project for HUD dispatch (falls back to CLAUDEMCP_PROJECT)
HUD_DISPATCH_MAX_MS=300000   # per-dispatch timeout
# Create a read-scoped ApiKey for the dispatch agent to call back into KanbanMCP:
# its permissions must be ["read","propose"] — this blocks every mutation tool
# (create_card/move_card/...) while allowing reads + propose_changeset.